# AI Kingdoms Root Environment
NODE_ENV=development

# Database
POSTGRES_USER=ai_kingdoms
POSTGRES_PASSWORD=kingdoms_secret
POSTGRES_DB=ai_kingdoms_db
DATABASE_URL=postgresql://ai_kingdoms:kingdoms_secret@localhost:5432/ai_kingdoms_db

# Redis
REDIS_URL=redis://localhost:6379

# JWT
JWT_SECRET=change_this_in_production_super_secret_key_256bit
JWT_EXPIRES_IN=7d

# Server
BACKEND_PORT=3000
FRONTEND_PORT=5173

# Simulation
SIM_TICK_MS=1000
SIM_AI_COUNT=1000
SIM_MAX_AI=10000

# Admin
ADMIN_EMAIL=admin@ai-kingdoms.com
ADMIN_PASSWORD=change_this_admin_password
